{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base", "default:automergeDigest"],
  "packageRules": [
    {
      "description": "Group Go stdlib / toolchain updates and automerge when tests pass",
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "matchDepTypes": ["golang", "toolchain"],
      "groupName": "go",
      "rangeStrategy": "bump",
      "automerge": true
    },
    {
      "description": "Group GitHub Actions updates and automerge when tests pass",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "matchDatasources": ["go", "github-releases", "github-tags"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    }
  ]
}
